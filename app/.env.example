# Database (Supabase Postgres — use the "connection string" from Supabase dashboard)
# For async SQLAlchemy, use postgresql+asyncpg:// instead of postgres://
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google OAuth
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# AI
ANTHROPIC_API_KEY=sk-ant-xxxx
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your-fernet-key-here

# Email (Resend)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=mail@mailfilter.com

# Task queue
REDIS_URL=redis://localhost:6379

# Session signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=change-me-to-a-random-secret

# App
APP_URL=http://localhost:8000
ENV=development
